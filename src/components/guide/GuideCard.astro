---
import { getTranslations, type Lang } from '../../i18n/ui';
import type { Category } from '../../content.config';

interface Props {
  title: string;
  description: string;
  category: Category;
  tags: string[];
  difficulty?: string;
  publishDate: Date;
  coverImage?: string;
  slug: string;
  lang: Lang;
}

const { title, description, category, tags, difficulty, publishDate, coverImage, slug, lang } = Astro.props;
const t = getTranslations(lang);

const difficultyColors: Record<string, string> = {
  beginner: 'bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-400',
  intermediate: 'bg-yellow-100 text-yellow-700 dark:bg-yellow-900/30 dark:text-yellow-400',
  advanced: 'bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-400',
};

const formattedDate = publishDate.toLocaleDateString(lang === 'zh-cn' ? 'zh-CN' : lang, {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<a
  href={`/${lang}/guides/${slug}`}
  class="group block rounded-xl overflow-hidden bg-white dark:bg-surface-900 border border-surface-200 dark:border-surface-800 hover:border-primary-300 dark:hover:border-primary-700 hover:shadow-lg transition-all duration-300"
>
  <!-- Cover Image -->
  <div class="aspect-video bg-surface-100 dark:bg-surface-800 relative overflow-hidden">
    {coverImage ? (
      <img src={coverImage} alt={title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />
    ) : (
      <div class="w-full h-full flex items-center justify-center text-surface-400">
        <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
      </div>
    )}
    <!-- Category Badge -->
    <span class="absolute top-3 left-3 px-2 py-1 text-xs font-semibold rounded-md bg-primary-600 text-white">
      {t[`category.${category}`]}
    </span>
  </div>

  <!-- Content -->
  <div class="p-4">
    <h3 class="text-lg font-bold text-surface-900 dark:text-surface-100 group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors line-clamp-2 mb-2">
      {title}
    </h3>
    <p class="text-sm text-surface-600 dark:text-surface-400 line-clamp-2 mb-3">
      {description}
    </p>

    <!-- Tags -->
    {tags.length > 0 && (
      <div class="flex flex-wrap gap-1.5 mb-3">
        {tags.slice(0, 3).map((tag) => (
          <span class="px-2 py-0.5 text-xs rounded-full bg-surface-100 dark:bg-surface-800 text-surface-600 dark:text-surface-400">
            {tag}
          </span>
        ))}
      </div>
    )}

    <!-- Footer -->
    <div class="flex items-center justify-between text-xs text-surface-500 dark:text-surface-500">
      <time datetime={publishDate.toISOString()}>{formattedDate}</time>
      {difficulty && (
        <span class:list={['px-2 py-0.5 rounded-full text-xs font-medium', difficultyColors[difficulty] || '']}>
          {difficulty}
        </span>
      )}
    </div>
  </div>
</a>
