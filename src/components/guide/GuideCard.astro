---
import { getTranslations, type Lang } from '../../i18n/ui';
import type { Category } from '../../content.config';

interface Props {
  title: string;
  description: string;
  category: Category;
  tags: string[];
  difficulty?: string;
  publishDate: Date;
  coverImage?: string;
  slug: string;
  lang: Lang;
}

const { title, description, category, tags, difficulty, publishDate, coverImage, slug, lang } = Astro.props;
const t = getTranslations(lang);

const difficultyColors: Record<string, string> = {
  beginner: 'bg-green-500 text-white',
  intermediate: 'bg-yellow-500 text-white',
  advanced: 'bg-red-500 text-white',
};

const categoryCSS: Record<string, string> = {
  story: 'cat-story',
  equipment: 'cat-equipment',
  skills: 'cat-skills',
  exploration: 'cat-exploration',
  mounts: 'cat-mounts',
  bosses: 'cat-bosses',
  beginners: 'cat-beginners',
  news: 'cat-news',
};

const formattedDate = publishDate.toLocaleDateString(lang === 'zh-cn' ? 'zh-CN' : lang, {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<a
  href={`/${lang}/guides/${slug}`}
  class="group card-shine block rounded-2xl overflow-hidden bg-white dark:bg-surface-900 border border-surface-200 dark:border-surface-800 hover:border-primary-300 dark:hover:border-primary-700 hover:shadow-xl transition-all duration-300 hover:-translate-y-1"
>
  <!-- Cover Image -->
  <div class="aspect-video relative overflow-hidden">
    {coverImage ? (
      <img src={coverImage} alt={title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
    ) : (
      <div class:list={['w-full h-full', categoryCSS[category] || 'bg-surface-100 dark:bg-surface-800']}></div>
    )}
    <!-- Category Badge -->
    <span class="absolute top-3 left-3 px-3 py-1 text-xs font-bold rounded-lg bg-primary-600 text-white shadow-md">
      {t[`category.${category}`]}
    </span>
    {difficulty && (
      <span class:list={['absolute top-3 right-3 px-2 py-1 text-xs font-bold rounded-lg', difficultyColors[difficulty] || '']}>
        {difficulty}
      </span>
    )}
  </div>

  <!-- Content -->
  <div class="p-5">
    <h3 class="text-lg font-bold text-surface-900 dark:text-surface-100 group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors line-clamp-2 mb-2">
      {title}
    </h3>
    <p class="text-sm text-surface-600 dark:text-surface-400 line-clamp-2 mb-3">
      {description}
    </p>

    <!-- Tags -->
    {tags.length > 0 && (
      <div class="flex flex-wrap gap-1.5 mb-3">
        {tags.slice(0, 3).map((tag) => (
          <span class="px-2 py-0.5 text-xs rounded-full bg-surface-100 dark:bg-surface-800 text-surface-500 dark:text-surface-400">
            #{tag}
          </span>
        ))}
      </div>
    )}

    <!-- Footer -->
    <div class="flex items-center justify-between text-xs text-surface-400 pt-2 border-t border-surface-100 dark:border-surface-800">
      <time datetime={publishDate.toISOString()}>{formattedDate}</time>
      <span class="text-primary-500 font-medium group-hover:translate-x-1 transition-transform inline-flex items-center gap-0.5">
        {t['guide.readMore']}
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
      </span>
    </div>
  </div>
</a>
