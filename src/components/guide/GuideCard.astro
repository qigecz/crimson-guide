---
import { getTranslations, type Lang } from '../../i18n/ui';
import type { Category } from '../../content.config';

interface Props {
  title: string;
  description: string;
  category: Category;
  tags: string[];
  difficulty?: string;
  publishDate: Date;
  coverImage?: string;
  slug: string;
  lang: Lang;
}

const { title, description, category, tags, difficulty, publishDate, coverImage, slug, lang } = Astro.props;
const t = getTranslations(lang);

const categoryEmoji: Record<string, string> = {
  story: '📖',
  equipment: '⚔️',
  skills: '✨',
  exploration: '🗺️',
  mounts: '🐴',
  bosses: '👹',
  beginners: '🔰',
  news: '📰',
};

const formattedDate = publishDate.toLocaleDateString(lang === 'zh-cn' ? 'zh-CN' : lang, {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<a
  href={`/${lang}/guides/${slug}`}
  class="group block py-4 border-b border-surface-100 dark:border-surface-800/50 hover:bg-surface-50 dark:hover:bg-surface-900/50 transition-colors px-3 -mx-3 rounded"
>
  <div class="flex items-start gap-4">
    <div class="flex-shrink-0 w-10 h-10 flex items-center justify-center text-xl bg-surface-50 dark:bg-surface-800 rounded-lg">
      {categoryEmoji[category] || '📄'}
    </div>
    <div class="flex-1 min-w-0">
      <div class="flex items-center gap-2 mb-1">
        <span class="text-xs text-surface-400 font-medium">{t[`category.${category}`]}</span>
        {difficulty && (
          <span class="text-xs text-surface-300 dark:text-surface-600">&middot;</span>
        )}
        {difficulty && (
          <span class="text-xs text-surface-400">{difficulty}</span>
        )}
      </div>
      <h3 class="text-sm font-semibold text-surface-900 dark:text-surface-100 group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors line-clamp-1 mb-1">
        {title}
      </h3>
      <p class="text-xs text-surface-400 line-clamp-2">
        {description}
      </p>
      <div class="flex items-center gap-3 mt-2">
        <time datetime={publishDate.toISOString()} class="text-xs text-surface-300 dark:text-surface-600">{formattedDate}</time>
        {tags.length > 0 && (
          <div class="flex gap-1.5">
            {tags.slice(0, 2).map((tag) => (
              <span class="text-xs text-surface-300 dark:text-surface-600">#{tag}</span>
            ))}
          </div>
        )}
      </div>
    </div>
  </div>
</a>
