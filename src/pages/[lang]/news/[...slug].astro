---
import type { GetStaticPaths } from 'astro';
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ReadingProgress from '../../../components/guide/ReadingProgress.tsx';
import TableOfContents from '../../../components/guide/TableOfContents.tsx';
import GiscusComments from '../../../components/comments/GiscusComments.tsx';
import { getTranslations, type Lang } from '../../../i18n/ui';

export const getStaticPaths: GetStaticPaths = async () => {
  const langs: Lang[] = ['en', 'zh-cn', 'ja', 'ko', 'es', 'pt'];
  const guides = await getCollection('guides');

  return guides.flatMap((entry) => {
    const match = entry.id.match(/^([a-z-]+)\/news\/(.+)$/);
    if (!match) return [];

    const [, entryLang, slug] = match;
    if (!langs.includes(entryLang as Lang)) return [];

    // Strip extension from slug
    const cleanSlug = slug.replace(/\.(md|mdx)$/, '');

    return { params: { lang: entryLang, slug: cleanSlug }, props: { entry } };
  });
};

const { lang } = Astro.params as { lang: Lang };
const { entry } = Astro.props;
const t = getTranslations(lang);

const { Content } = await render(entry);

const formattedDate = entry.data.publishDate.toLocaleDateString(
  lang === 'zh-cn' ? 'zh-CN' : lang,
  { year: 'numeric', month: 'long', day: 'numeric' }
);

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "NewsArticle",
  "headline": entry.data.title,
  "description": entry.data.description,
  "author": { "@type": "Organization", "name": entry.data.author },
  "datePublished": entry.data.publishDate.toISOString(),
  "publisher": { "@type": "Organization", "name": "Crimson Guide" },
  "inLanguage": lang,
};
---

<BaseLayout title={entry.data.title} description={entry.data.description} articleSchema={articleSchema}>
  <ReadingProgress client:load />

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <nav class="mb-6 text-sm text-surface-500 dark:text-surface-400" aria-label="Breadcrumb">
      <ol class="flex items-center gap-2 flex-wrap">
        <li><a href={`/${lang}`} class="hover:text-primary-600">{t['nav.home']}</a></li>
        <li>/</li>
        <li><a href={`/${lang}/news`} class="hover:text-primary-600">{t['nav.news']}</a></li>
        <li>/</li>
        <li class="text-surface-900 dark:text-surface-100 truncate max-w-[200px]">{entry.data.title}</li>
      </ol>
    </nav>

    <div class="lg:grid lg:grid-cols-12 lg:gap-8">
      <aside class="hidden lg:block lg:col-span-3">
        <div class="sticky top-24 max-h-[calc(100vh-8rem)] overflow-y-auto">
          <TableOfContents client:load />
        </div>
      </aside>

      <article class="lg:col-span-9">
        <header class="mb-8">
          <div class="flex items-center gap-2 mb-4">
            <span class="px-3 py-1 text-sm font-medium rounded-lg bg-primary-50 dark:bg-primary-900/30 text-primary-700 dark:text-primary-400">
              {t['category.news']}
            </span>
          </div>

          <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-surface-900 dark:text-surface-100 mb-4">
            {entry.data.title}
          </h1>
          <p class="text-lg text-surface-600 dark:text-surface-400 mb-4">{entry.data.description}</p>
          <div class="flex items-center gap-4 text-sm text-surface-500">
            <span>By {entry.data.author}</span>
            <span>•</span>
            <time datetime={entry.data.publishDate.toISOString()}>{formattedDate}</time>
          </div>

          {entry.data.tags.length > 0 && (
            <div class="flex flex-wrap gap-2 mt-4">
              {entry.data.tags.map((tag: string) => (
                <span class="px-2 py-1 text-xs rounded-full bg-surface-100 dark:bg-surface-800 text-surface-600 dark:text-surface-400">#{tag}</span>
              ))}
            </div>
          )}
        </header>

        <div class="prose max-w-none" data-pagefind-body>
          <Content />
        </div>

        <div class="mt-12 pt-8 border-t border-surface-200 dark:border-surface-800">
          <h2 class="text-2xl font-bold text-surface-900 dark:text-surface-100 mb-6">Comments</h2>
          <GiscusComments client:visible lang={lang} />
        </div>
      </article>
    </div>
  </div>
</BaseLayout>
