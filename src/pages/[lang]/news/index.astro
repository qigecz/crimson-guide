---
import type { GetStaticPaths } from 'astro';
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getTranslations, type Lang } from '../../../i18n/ui';

export const getStaticPaths: GetStaticPaths = async () => {
  const langs: Lang[] = ['en', 'zh-cn', 'ja', 'ko', 'es', 'pt'];
  return langs.map((lang) => ({ params: { lang } }));
};

const { lang } = Astro.params as { lang: Lang };
const t = getTranslations(lang);

const allGuides = await getCollection('guides');
const newsArticles = allGuides
  .filter((entry) => entry.id.startsWith(`${lang}/`) && entry.data.category === 'news')
  .sort((a, b) => {
    const dateA = a.data.publishDate?.getTime() || 0;
    const dateB = b.data.publishDate?.getTime() || 0;
    return dateB - dateA;
  });
---

<BaseLayout title={t['nav.news']} description="Latest news and updates about Crimson Desert">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 page-enter">
    <div class="mb-10">
      <h1 class="text-4xl md:text-5xl font-extrabold text-surface-900 dark:text-surface-100 mb-3">
        {t['nav.news']}
      </h1>
      <p class="text-lg text-surface-500 dark:text-surface-400">
        {t['section.latest']}
      </p>
    </div>

    {newsArticles.length > 0 ? (
      <div class="space-y-4">
        {newsArticles.map((article) => {
          const slug = article.id
            .replace(new RegExp(`^${lang}/`), '')
            .replace(/\.(md|mdx)$/, '');
          return (
            <a
              href={`/${lang}/${slug}`}
              class="group block p-6 rounded-2xl bg-white dark:bg-surface-900 border border-surface-200 dark:border-surface-800 hover:border-primary-300 dark:hover:border-primary-700 hover:shadow-lg transition-all duration-300"
            >
              <div class="flex items-center gap-3 mb-3">
                <span class="px-3 py-1 text-xs font-bold rounded-lg bg-primary-100 dark:bg-primary-900/30 text-primary-700 dark:text-primary-400">NEWS</span>
                <time class="text-sm text-surface-400">{article.data.publishDate.toLocaleDateString(lang === 'zh-cn' ? 'zh-CN' : lang, { month: 'long', day: 'numeric', year: 'numeric' })}</time>
              </div>
              <h2 class="text-xl font-bold text-surface-900 dark:text-surface-100 group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors mb-2">
                {article.data.title}
              </h2>
              <p class="text-surface-500 dark:text-surface-400 line-clamp-2">{article.data.description}</p>
              {article.data.tags.length > 0 && (
                <div class="flex flex-wrap gap-1.5 mt-3">
                  {article.data.tags.slice(0, 4).map((tag: string) => (
                    <span class="px-2 py-0.5 text-xs rounded-full bg-surface-100 dark:bg-surface-800 text-surface-500">#{tag}</span>
                  ))}
                </div>
              )}
            </a>
          );
        })}
      </div>
    ) : (
      <div class="text-center py-24">
        <div class="w-16 h-16 mx-auto mb-4 text-surface-300 dark:text-surface-600">
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" /></svg>
        </div>
        <p class="text-surface-400 dark:text-surface-500 text-lg">{lang === 'zh-cn' ? '暂无新闻。' : 'No news available yet in this language.'}</p>
      </div>
    )}
  </div>
</BaseLayout>
