---
import type { GetStaticPaths } from 'astro';
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getTranslations, type Lang } from '../../../i18n/ui';

export const getStaticPaths: GetStaticPaths = async () => {
  const langs: Lang[] = ['en', 'zh-cn', 'ja', 'ko', 'es', 'pt'];
  return langs.map((lang) => ({ params: { lang } }));
};

const { lang } = Astro.params as { lang: Lang };
const t = getTranslations(lang);

const allGuides = await getCollection('guides');
const newsArticles = allGuides
  .filter((entry) => entry.id.startsWith(`${lang}/`) && entry.data.category === 'news')
  .sort((a, b) => {
    const dateA = a.data.publishDate?.getTime() || 0;
    const dateB = b.data.publishDate?.getTime() || 0;
    return dateB - dateA;
  });
---

<BaseLayout title={t['nav.news']} description="Latest news and updates about Crimson Desert">
  <div class="max-w-5xl mx-auto px-6 py-12">
    <h1 class="text-2xl font-bold text-surface-900 dark:text-surface-100 mb-2">
      {t['nav.news']}
    </h1>
    <p class="text-sm text-surface-400 mb-8">
      {t['section.latest']}
    </p>

    {newsArticles.length > 0 ? (
      <div>
        {newsArticles.map((article) => {
          const slug = article.id
            .replace(new RegExp(`^${lang}/`), '')
            .replace(/\.(md|mdx)$/, '');
          return (
            <a
              href={`/${lang}/${slug}`}
              class="group flex items-start gap-3 py-4 border-b border-surface-100 dark:border-surface-800/50 hover:bg-surface-50 dark:hover:bg-surface-900/50 transition-colors px-3 -mx-3 rounded"
            >
              <div class="flex-shrink-0 w-9 h-9 flex items-center justify-center text-lg bg-surface-50 dark:bg-surface-800 rounded-lg">
                📰
              </div>
              <div class="flex-1 min-w-0">
                <h2 class="text-sm font-medium text-surface-900 dark:text-surface-100 group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors line-clamp-1">
                  {article.data.title}
                </h2>
                <p class="text-xs text-surface-400 line-clamp-1 mt-0.5">
                  {article.data.description}
                </p>
                <div class="flex items-center gap-2 mt-1.5">
                  <time class="text-xs text-surface-300">{article.data.publishDate.toLocaleDateString(lang === 'zh-cn' ? 'zh-CN' : lang, { month: 'short', day: 'numeric', year: 'numeric' })}</time>
                  {article.data.tags.length > 0 && (
                    <div class="flex gap-1.5">
                      {article.data.tags.slice(0, 2).map((tag: string) => (
                        <span class="text-xs text-surface-300">#{tag}</span>
                      ))}
                    </div>
                  )}
                </div>
              </div>
            </a>
          );
        })}
      </div>
    ) : (
      <div class="text-center py-20">
        <p class="text-surface-400 text-sm">{lang === 'zh-cn' ? '暂无新闻。' : 'No news available yet in this language.'}</p>
      </div>
    )}
  </div>
</BaseLayout>
