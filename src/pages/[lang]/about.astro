---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getTranslations, type Lang } from '../../i18n/ui';

export const getStaticPaths: GetStaticPaths = async () => {
  const langs: Lang[] = ['en', 'zh-cn', 'ja', 'ko', 'es', 'pt'];
  return langs.map((lang) => ({ params: { lang } }));
};

const { lang } = Astro.params as { lang: Lang };
const t = getTranslations(lang);

const aboutContent: Record<Lang, { title: string; sections: { heading: string; body: string; icon: string }[] }> = {
  en: {
    title: 'About Crimson Guide',
    sections: [
      {
        heading: 'Our Mission',
        body: 'Crimson Guide is a fan-made resource dedicated to helping players navigate the world of Crimson Desert. Our goal is to provide comprehensive, accurate, and up-to-date guides for players around the world.',
        icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>`,
      },
      {
        heading: 'Disclaimer',
        body: 'This website is not affiliated with, endorsed by, or connected to Pearl Abyss. Crimson Desert is a trademark of Pearl Abyss. All game assets, logos, and names are property of their respective owners.',
        icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>`,
      },
      {
        heading: 'Contributing',
        body: 'We welcome contributions from the community! If you\'d like to help improve our guides, fix errors, or add new content, feel free to reach out. Together we can build the best Crimson Desert resource.',
        icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>`,
      },
      {
        heading: 'Contact',
        body: 'Have questions or suggestions? Reach out to us on our social media channels or open an issue on our GitHub repository.',
        icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>`,
      },
    ],
  },
  'zh-cn': {
    title: '关于 Crimson Guide',
    sections: [
      {
        heading: '我们的使命',
        body: 'Crimson Guide 是一个玩家自制资源站，致力于帮助玩家探索《红色沙漠》的世界。我们的目标是为全球玩家提供全面、准确、及时的攻略内容。',
        icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>`,
      },
      {
        heading: '免责声明',
        body: '本站与 Pearl Abyss 无任何关联、不代表、也不连接 Pearl Abyss。《红色沙漠》是 Pearl Abyss 的商标。所有游戏素材、标识和名称均为其各自所有者的财产。',
        icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>`,
      },
      {
        heading: '参与贡献',
        body: '我们欢迎社区贡献！如果您想帮助改进攻略、修复错误或添加新内容，欢迎联系我们。让我们一起打造最好的《红色沙漠》攻略资源。',
        icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>`,
      },
      {
        heading: '联系方式',
        body: '有任何问题或建议？请在社交媒体上联系我们，或在我们 GitHub 仓库中提交 Issue。',
        icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>`,
      },
    ],
  },
  ja: {
    title: 'Crimson Guide について',
    sections: [
      { heading: '私たちの使命', body: 'Crimson Guide は、Crimson Desert の世界をナビゲートするプレイヤーを支援するために作られたファンサイトです。世界中のプレイヤーに包括的で正確なガイドを提供することを目指しています。', icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>` },
      { heading: '免責事項', body: 'このウェブサイトは Pearl Abyss と提携、推奨、または接続されていません。Crimson Desert は Pearl Abyss の商標です。', icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>` },
      { heading: '貢献', body: 'コミュニティからの貢献を歓迎します！ガイドの改善にご協力ください。', icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>` },
      { heading: 'お問い合わせ', body: 'ご質問やご提案がありましたら、ソーシャルメディアにてお問い合わせください。', icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>` },
    ],
  },
  ko: {
    title: 'Crimson Guide 소개',
    sections: [
      { heading: '우리의 사명', body: 'Crimson Guide는 Crimson Desert 세계를 탐험하는 플레이어를 돕기 위해 만든 팬 사이트입니다.', icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>` },
      { heading: '면책 조항', body: '이 웹사이트는 Pearl Abyss와 제휴, 보증 또는 연결되어 있지 않습니다.', icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>` },
      { heading: '기여', body: '커뮤니티의 기여를 환영합니다! 가이드 개선에 도움을 주세요.', icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>` },
      { heading: '연락처', body: '질문이나 제안이 있으시면 소셜 미디어로 연락해 주세요.', icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>` },
    ],
  },
  es: {
    title: 'Sobre Crimson Guide',
    sections: [
      { heading: 'Nuestra Misión', body: 'Crimson Guide es un recurso hecho por fans dedicado a ayudar a los jugadores a navegar el mundo de Crimson Desert.', icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>` },
      { heading: 'Aviso Legal', body: 'Este sitio web no está afiliado con Pearl Abyss. Crimson Desert es una marca registrada de Pearl Abyss.', icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>` },
      { heading: 'Contribuir', body: '¡Agradecemos las contribuciones de la comunidad! Ayúdanos a mejorar las guías.', icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>` },
      { heading: 'Contacto', body: '¿Tienes preguntas o sugerencias? Contáctanos en redes sociales.', icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>` },
    ],
  },
  pt: {
    title: 'Sobre o Crimson Guide',
    sections: [
      { heading: 'Nossa Missão', body: 'Crimson Guide é um recurso feito por fãs dedicado a ajudar jogadores a navegar pelo mundo de Crimson Desert.', icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>` },
      { heading: 'Aviso Legal', body: 'Este site não é afiliado à Pearl Abyss. Crimson Desert é uma marca registrada da Pearl Abyss.', icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>` },
      { heading: 'Contribuir', body: 'Agradecemos contribuições da comunidade! Ajude-nos a melhorar os guias.', icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>` },
      { heading: 'Contato', body: 'Tem perguntas ou sugestões? Entre em contato pelas redes sociais.', icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>` },
    ],
  },
};

const content = aboutContent[lang] || aboutContent.en;
---

<BaseLayout title={t['nav.about']} description={content.title}>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8 page-enter">
    <h1 class="text-4xl md:text-5xl font-extrabold text-surface-900 dark:text-surface-100 mb-10">
      {content.title}
    </h1>

    <div class="space-y-6">
      {content.sections.map((section) => (
        <section class="bg-white dark:bg-surface-900 rounded-2xl border border-surface-200 dark:border-surface-800 p-6 hover:border-primary-200 dark:hover:border-primary-800 transition-colors">
          <div class="flex items-center gap-3 mb-3">
            <div class="flex items-center justify-center w-10 h-10 rounded-xl bg-primary-100 dark:bg-primary-900/30 text-primary-600 dark:text-primary-400">
              <Fragment set:html={section.icon} />
            </div>
            <h2 class="text-xl font-bold text-surface-900 dark:text-surface-100">
              {section.heading}
            </h2>
          </div>
          <p class="text-surface-600 dark:text-surface-400 leading-relaxed pl-13">
            {section.body}
          </p>
        </section>
      ))}
    </div>

    <!-- Links -->
    <div class="mt-10 flex flex-wrap gap-4">
      <a
        href={`/${lang}/guides`}
        class="px-8 py-3.5 rounded-xl bg-primary-600 text-white font-bold hover:bg-primary-700 transition-all duration-300 shadow-lg hover:shadow-xl hover:-translate-y-0.5"
      >
        {t['hero.cta.guides']}
      </a>
      <a
        href={`/${lang}/map`}
        class="px-8 py-3.5 rounded-xl bg-surface-100 dark:bg-surface-800 text-surface-700 dark:text-surface-300 font-bold hover:bg-surface-200 dark:hover:bg-surface-700 transition-all duration-300"
      >
        {t['hero.cta.map']}
      </a>
      <a
        href={`/${lang}/contact`}
        class="px-8 py-3.5 rounded-xl bg-surface-100 dark:bg-surface-800 text-surface-700 dark:text-surface-300 font-bold hover:bg-surface-200 dark:hover:bg-surface-700 transition-all duration-300"
      >
        {t['nav.contact']}
      </a>
    </div>
  </div>
</BaseLayout>
