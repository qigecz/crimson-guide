---
import type { GetStaticPaths } from 'astro';
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import GuideCard from '../../../components/guide/GuideCard.astro';
import { getTranslations, type Lang } from '../../../i18n/ui';

export const getStaticPaths: GetStaticPaths = async () => {
  const langs: Lang[] = ['en', 'zh-cn', 'ja', 'ko', 'es', 'pt'];
  return langs.map((lang) => ({ params: { lang } }));
};

const { lang } = Astro.params as { lang: Lang };
const t = getTranslations(lang);

// Get all guides (non-news) for this language
const allGuides = await getCollection('guides');
const langGuides = allGuides
  .filter((entry) => entry.id.startsWith(`${lang}/guides/`))
  .sort((a, b) => {
    const dateA = a.data.publishDate?.getTime() || 0;
    const dateB = b.data.publishDate?.getTime() || 0;
    return dateB - dateA;
  });
---

<BaseLayout title={t['nav.guides']} description={t['hero.subtitle']}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="mb-8">
      <h1 class="text-3xl md:text-4xl font-bold text-surface-900 dark:text-surface-100 mb-2">
        {t['nav.guides']}
      </h1>
      <p class="text-surface-600 dark:text-surface-400">{t['hero.subtitle']}</p>
    </div>

    <div class="flex flex-wrap gap-2 mb-8">
      <a href={`/${lang}/guides`} class="px-4 py-2 text-sm font-medium rounded-lg bg-primary-600 text-white">
        {t['hero.cta.guides']}
      </a>
      {['story', 'equipment', 'skills', 'exploration', 'mounts', 'bosses', 'beginners'].map((cat) => (
        <a href={`/${lang}/guides/${cat}`} class="px-4 py-2 text-sm font-medium rounded-lg bg-surface-100 dark:bg-surface-800 text-surface-600 dark:text-surface-400 hover:bg-surface-200 dark:hover:bg-surface-700 transition-colors">
          {t[`category.${cat}`]}
        </a>
      ))}
    </div>

    {langGuides.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {langGuides.map((guide) => {
          const slug = guide.id
            .replace(new RegExp(`^${lang}/guides/`), '')
            .replace(/\.(md|mdx)$/, '');
          return (
            <GuideCard
              title={guide.data.title}
              description={guide.data.description}
              category={guide.data.category}
              tags={guide.data.tags}
              difficulty={guide.data.difficulty}
              publishDate={guide.data.publishDate}
              coverImage={guide.data.coverImage}
              slug={slug}
              lang={lang}
            />
          );
        })}
      </div>
    ) : (
      <div class="text-center py-16">
        <p class="text-surface-500 dark:text-surface-400 text-lg">No guides available yet in this language.</p>
      </div>
    )}
  </div>
</BaseLayout>
