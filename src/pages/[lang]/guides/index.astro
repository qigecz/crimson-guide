---
import type { GetStaticPaths } from 'astro';
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import GuideCard from '../../../components/guide/GuideCard.astro';
import { getTranslations, type Lang } from '../../../i18n/ui';

export const getStaticPaths: GetStaticPaths = async () => {
  const langs: Lang[] = ['en', 'zh-cn', 'ja', 'ko', 'es', 'pt'];
  return langs.map((lang) => ({ params: { lang } }));
};

const { lang } = Astro.params as { lang: Lang };
const t = getTranslations(lang);

const allCategoryKeys = ['story', 'equipment', 'skills', 'exploration', 'mounts', 'bosses', 'beginners'] as const;

// Get all guides (non-news) for this language
const allGuides = await getCollection('guides');
const langGuides = allGuides
  .filter((entry) => entry.id.startsWith(`${lang}/guides/`))
  .sort((a, b) => {
    const dateA = a.data.publishDate?.getTime() || 0;
    const dateB = b.data.publishDate?.getTime() || 0;
    return dateB - dateA;
  });
---

<BaseLayout title={t['nav.guides']} description={t['hero.subtitle']}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 page-enter">
    <!-- Header -->
    <div class="mb-10">
      <h1 class="text-4xl md:text-5xl font-extrabold text-surface-900 dark:text-surface-100 mb-3">
        {t['nav.guides']}
      </h1>
      <p class="text-lg text-surface-500 dark:text-surface-400">{t['hero.subtitle']}</p>
    </div>

    <!-- Category Filter -->
    <div class="flex flex-wrap gap-2 mb-10">
      <a href={`/${lang}/guides`} class="px-5 py-2.5 text-sm font-bold rounded-xl bg-primary-600 text-white shadow-md hover:bg-primary-700 transition-colors">
        {lang === 'zh-cn' ? '全部' : 'All'}
      </a>
      {allCategoryKeys.map((cat) => (
        <a href={`/${lang}/guides/${cat}`} class="px-5 py-2.5 text-sm font-medium rounded-xl bg-surface-100 dark:bg-surface-800 text-surface-600 dark:text-surface-400 hover:bg-surface-200 dark:hover:bg-surface-700 hover:text-primary-600 dark:hover:text-primary-400 transition-all duration-200">
          {t[`category.${cat}`]}
        </a>
      ))}
    </div>

    {langGuides.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {langGuides.map((guide) => {
          const slug = guide.id
            .replace(new RegExp(`^${lang}/guides/`), '')
            .replace(/\.(md|mdx)$/, '');
          return (
            <GuideCard
              title={guide.data.title}
              description={guide.data.description}
              category={guide.data.category}
              tags={guide.data.tags}
              difficulty={guide.data.difficulty}
              publishDate={guide.data.publishDate}
              coverImage={guide.data.coverImage}
              slug={slug}
              lang={lang}
            />
          );
        })}
      </div>
    ) : (
      <div class="text-center py-24">
        <div class="w-16 h-16 mx-auto mb-4 text-surface-300 dark:text-surface-600">
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" /></svg>
        </div>
        <p class="text-surface-400 dark:text-surface-500 text-lg">No guides available yet in this language.</p>
      </div>
    )}
  </div>
</BaseLayout>
