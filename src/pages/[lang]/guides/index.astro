---
import type { GetStaticPaths } from 'astro';
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import GuideCard from '../../../components/guide/GuideCard.astro';
import { getTranslations, type Lang } from '../../../i18n/ui';

export const getStaticPaths: GetStaticPaths = async () => {
  const langs: Lang[] = ['en', 'zh-cn', 'ja', 'ko', 'es', 'pt'];
  return langs.map((lang) => ({ params: { lang } }));
};

const { lang } = Astro.params as { lang: Lang };
const t = getTranslations(lang);

const allCategoryKeys = ['story', 'equipment', 'skills', 'exploration', 'mounts', 'bosses', 'beginners'] as const;

const categoryEmoji: Record<string, string> = {
  story: '📖', equipment: '⚔️', skills: '✨', exploration: '🗺️',
  mounts: '🐴', bosses: '👹', beginners: '🔰',
};

const allGuides = await getCollection('guides');
const langGuides = allGuides
  .filter((entry) => entry.id.startsWith(`${lang}/guides/`))
  .sort((a, b) => {
    const dateA = a.data.publishDate?.getTime() || 0;
    const dateB = b.data.publishDate?.getTime() || 0;
    return dateB - dateA;
  });
---

<BaseLayout title={t['nav.guides']} description={t['hero.subtitle']}>
  <div class="max-w-5xl mx-auto px-6 py-12">
    <h1 class="text-2xl font-bold text-surface-900 dark:text-surface-100 mb-2">
      {t['nav.guides']}
    </h1>
    <p class="text-sm text-surface-400 mb-8">{t['hero.subtitle']}</p>

    <div class="flex flex-wrap gap-2 mb-8">
      <a href={`/${lang}/guides`} class="px-4 py-2 text-sm font-medium bg-surface-900 text-white dark:bg-surface-100 dark:text-surface-900 rounded-lg">
        {lang === 'zh-cn' ? '全部' : 'All'}
      </a>
      {allCategoryKeys.map((cat) => (
        <a href={`/${lang}/guides/${cat}`} class="inline-flex items-center gap-1.5 px-4 py-2 text-sm text-surface-500 dark:text-surface-400 bg-surface-50 dark:bg-surface-800/50 rounded-lg hover:bg-surface-100 dark:hover:bg-surface-800 transition-colors">
          <span>{categoryEmoji[cat]}</span>
          {t[`category.${cat}`]}
        </a>
      ))}
    </div>

    {langGuides.length > 0 ? (
      <div>
        {langGuides.map((guide) => {
          const slug = guide.id
            .replace(new RegExp(`^${lang}/guides/`), '')
            .replace(/\.(md|mdx)$/, '');
          return (
            <GuideCard
              title={guide.data.title}
              description={guide.data.description}
              category={guide.data.category}
              tags={guide.data.tags}
              difficulty={guide.data.difficulty}
              publishDate={guide.data.publishDate}
              coverImage={guide.data.coverImage}
              slug={slug}
              lang={lang}
            />
          );
        })}
      </div>
    ) : (
      <div class="text-center py-20">
        <p class="text-surface-400 text-sm">{lang === 'zh-cn' ? '暂无攻略。' : 'No guides available yet in this language.'}</p>
      </div>
    )}
  </div>
</BaseLayout>
