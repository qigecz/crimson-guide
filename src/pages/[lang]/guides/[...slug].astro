---
import type { GetStaticPaths } from 'astro';
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ReadingProgress from '../../../components/guide/ReadingProgress.tsx';
import TableOfContents from '../../../components/guide/TableOfContents.tsx';
import GiscusComments from '../../../components/comments/GiscusComments.tsx';
import { getTranslations, type Lang } from '../../../i18n/ui';

export const getStaticPaths: GetStaticPaths = async () => {
  const langs: Lang[] = ['en', 'zh-cn', 'ja', 'ko', 'es', 'pt'];
  const guides = await getCollection('guides');

  return guides.flatMap((entry) => {
    const match = entry.id.match(/^([a-z-]+)\/(.+)$/);
    if (!match) return [];

    const [, entryLang, fullPath] = match;
    if (!langs.includes(entryLang as Lang)) return [];

    if (fullPath.startsWith('guides/')) {
      const slug = fullPath.replace(/^guides\//, '');
      return { params: { lang: entryLang, slug }, props: { entry } };
    }
    return [];
  });
};

const { lang } = Astro.params as { lang: Lang };
const { entry } = Astro.props;
const t = getTranslations(lang);

const { Content } = await render(entry);

const formattedDate = entry.data.publishDate.toLocaleDateString(
  lang === 'zh-cn' ? 'zh-CN' : lang,
  { year: 'numeric', month: 'long', day: 'numeric' }
);

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": entry.data.title,
  "description": entry.data.description,
  "author": { "@type": "Organization", "name": entry.data.author },
  "datePublished": entry.data.publishDate.toISOString(),
  "dateModified": (entry.data.updateDate || entry.data.publishDate).toISOString(),
  "publisher": { "@type": "Organization", "name": "Crimson Guide" },
  "inLanguage": lang,
};
---

<BaseLayout title={entry.data.title} description={entry.data.description} articleSchema={articleSchema}>
  <ReadingProgress client:load />

  <div class="max-w-3xl mx-auto px-6 py-12">
    <!-- Breadcrumb -->
    <nav class="mb-8 text-xs text-surface-400" aria-label="Breadcrumb">
      <ol class="flex items-center gap-1.5 flex-wrap">
        <li><a href={`/${lang}`} class="hover:text-surface-600 dark:hover:text-surface-300 transition-colors">{t['nav.home']}</a></li>
        <li class="text-surface-300 dark:text-surface-600">/</li>
        <li><a href={`/${lang}/guides`} class="hover:text-surface-600 dark:hover:text-surface-300 transition-colors">{t['nav.guides']}</a></li>
        <li class="text-surface-300 dark:text-surface-600">/</li>
        <li><a href={`/${lang}/guides/${entry.data.category}`} class="hover:text-surface-600 dark:hover:text-surface-300 transition-colors">{t[`category.${entry.data.category}`]}</a></li>
        <li class="text-surface-300 dark:text-surface-600">/</li>
        <li class="text-surface-600 dark:text-surface-300 truncate max-w-[200px]">{entry.data.title}</li>
      </ol>
    </nav>

    <div class="lg:flex lg:gap-12">
      <!-- Sidebar TOC (desktop) -->
      <aside class="hidden lg:block lg:w-48 lg:flex-shrink-0">
        <div class="sticky top-20">
          <TableOfContents client:load />
        </div>
      </aside>

      <!-- Article -->
      <article class="flex-1 min-w-0">
        <header class="mb-10 pb-8 border-b border-surface-200 dark:border-surface-800">
          <div class="flex items-center gap-2 mb-4">
            <span class="text-xs font-medium text-surface-400">
              {t[`category.${entry.data.category}`]}
            </span>
            {entry.data.difficulty && (
              <>
                <span class="text-surface-300 dark:text-surface-600">&middot;</span>
                <span class="text-xs text-surface-400">{entry.data.difficulty}</span>
              </>
            )}
          </div>

          <h1 class="text-2xl md:text-3xl font-bold text-surface-900 dark:text-surface-100 mb-4 leading-snug">
            {entry.data.title}
          </h1>
          <p class="text-sm text-surface-400 mb-4 leading-relaxed">{entry.data.description}</p>

          <div class="flex items-center gap-4 text-xs text-surface-400">
            <span>{entry.data.author}</span>
            <span>&middot;</span>
            <time datetime={entry.data.publishDate.toISOString()}>{formattedDate}</time>
          </div>

          {entry.data.tags.length > 0 && (
            <div class="flex flex-wrap gap-1.5 mt-4">
              {entry.data.tags.map((tag: string) => (
                <span class="text-xs text-surface-400">#{tag}</span>
              ))}
            </div>
          )}
        </header>

        <!-- Mobile TOC -->
        <div class="lg:hidden mb-8 p-4 bg-surface-50 dark:bg-surface-900 rounded-lg border border-surface-200 dark:border-surface-800">
          <TableOfContents client:load />
        </div>

        <!-- Article Content -->
        <div class="prose max-w-none" data-pagefind-body>
          <Content />
        </div>

        <!-- Related Guides -->
        {entry.data.relatedGuides.length > 0 && (
          <div class="mt-12 pt-8 border-t border-surface-200 dark:border-surface-800">
            <h2 class="text-lg font-bold text-surface-900 dark:text-surface-100 mb-4">{t['guide.related']}</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
              {entry.data.relatedGuides.map((relatedSlug: string) => (
                <a href={`/${lang}/guides/${relatedSlug}`} class="group block p-4 rounded-lg border border-surface-200 dark:border-surface-800 hover:border-surface-300 dark:hover:border-surface-700 transition-colors">
                  <span class="text-sm text-surface-700 dark:text-surface-300 group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors">{relatedSlug}</span>
                  <svg class="w-3.5 h-3.5 inline-block ml-1 group-hover:translate-x-0.5 transition-transform text-surface-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
                </a>
              ))}
            </div>
          </div>
        )}

        <!-- Comments -->
        <div class="mt-12 pt-8 border-t border-surface-200 dark:border-surface-800">
          <h2 class="text-lg font-bold text-surface-900 dark:text-surface-100 mb-4">Comments</h2>
          <GiscusComments client:visible lang={lang} />
        </div>
      </article>
    </div>
  </div>
</BaseLayout>
