---
import type { GetStaticPaths } from 'astro';
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ReadingProgress from '../../../components/guide/ReadingProgress.tsx';
import TableOfContents from '../../../components/guide/TableOfContents.tsx';
import GiscusComments from '../../../components/comments/GiscusComments.tsx';
import { getTranslations, type Lang } from '../../../i18n/ui';

export const getStaticPaths: GetStaticPaths = async () => {
  const langs: Lang[] = ['en', 'zh-cn', 'ja', 'ko', 'es', 'pt'];
  const guides = await getCollection('guides');

  return guides.flatMap((entry) => {
    const match = entry.id.match(/^([a-z-]+)\/(.+)$/);
    if (!match) return [];

    const [, entryLang, fullPath] = match;
    if (!langs.includes(entryLang as Lang)) return [];

    if (fullPath.startsWith('guides/')) {
      const slug = fullPath.replace(/^guides\//, '');
      return { params: { lang: entryLang, slug }, props: { entry } };
    }
    return [];
  });
};

const { lang } = Astro.params as { lang: Lang };
const { entry } = Astro.props;
const t = getTranslations(lang);

const { Content } = await render(entry);

const formattedDate = entry.data.publishDate.toLocaleDateString(
  lang === 'zh-cn' ? 'zh-CN' : lang,
  { year: 'numeric', month: 'long', day: 'numeric' }
);

const difficultyColors: Record<string, string> = {
  beginner: 'bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-400',
  intermediate: 'bg-yellow-100 text-yellow-700 dark:bg-yellow-900/30 dark:text-yellow-400',
  advanced: 'bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-400',
};

const difficultyLabels: Record<string, Record<string, string>> = {
  beginner: { en: 'Beginner', 'zh-cn': '新手', ja: '初心者', ko: '초보자', es: 'Principiante', pt: 'Iniciante' },
  intermediate: { en: 'Intermediate', 'zh-cn': '进阶', ja: '中級者', ko: '중급자', es: 'Intermedio', pt: 'Intermediário' },
  advanced: { en: 'Advanced', 'zh-cn': '高级', ja: '上級者', ko: '고급자', es: 'Avanzado', pt: 'Avançado' },
};

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": entry.data.title,
  "description": entry.data.description,
  "author": { "@type": "Organization", "name": entry.data.author },
  "datePublished": entry.data.publishDate.toISOString(),
  "dateModified": (entry.data.updateDate || entry.data.publishDate).toISOString(),
  "publisher": { "@type": "Organization", "name": "Crimson Guide" },
  "inLanguage": lang,
};
---

<BaseLayout title={entry.data.title} description={entry.data.description} articleSchema={articleSchema}>
  <ReadingProgress client:load />

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 page-enter">
    <!-- Breadcrumb -->
    <nav class="mb-6 text-sm text-surface-400 dark:text-surface-500" aria-label="Breadcrumb">
      <ol class="flex items-center gap-2 flex-wrap">
        <li><a href={`/${lang}`} class="hover:text-primary-600 dark:hover:text-primary-400 transition-colors">{t['nav.home']}</a></li>
        <li class="text-surface-300 dark:text-surface-600">/</li>
        <li><a href={`/${lang}/guides`} class="hover:text-primary-600 dark:hover:text-primary-400 transition-colors">{t['nav.guides']}</a></li>
        <li class="text-surface-300 dark:text-surface-600">/</li>
        <li><a href={`/${lang}/guides/${entry.data.category}`} class="hover:text-primary-600 dark:hover:text-primary-400 transition-colors">{t[`category.${entry.data.category}`]}</a></li>
        <li class="text-surface-300 dark:text-surface-600">/</li>
        <li class="text-surface-700 dark:text-surface-300 truncate max-w-[200px]">{entry.data.title}</li>
      </ol>
    </nav>

    <div class="lg:grid lg:grid-cols-12 lg:gap-8">
      <!-- Sidebar TOC -->
      <aside class="hidden lg:block lg:col-span-3">
        <div class="sticky top-24 max-h-[calc(100vh-8rem)] overflow-y-auto rounded-2xl bg-surface-50 dark:bg-surface-900 border border-surface-200 dark:border-surface-800 p-4">
          <TableOfContents client:load />
        </div>
      </aside>

      <!-- Article -->
      <article class="lg:col-span-9">
        <!-- Article Header -->
        <header class="mb-10 pb-8 border-b border-surface-200 dark:border-surface-800">
          <div class="flex items-center gap-2 mb-5">
            <span class="px-3 py-1 text-sm font-bold rounded-lg bg-primary-100 dark:bg-primary-900/30 text-primary-700 dark:text-primary-400">
              {t[`category.${entry.data.category}`]}
            </span>
            {entry.data.difficulty && (
              <span class:list={['px-3 py-1 text-sm font-bold rounded-lg', difficultyColors[entry.data.difficulty] || '']}>
                {(difficultyLabels[entry.data.difficulty] || {})[lang] || entry.data.difficulty}
              </span>
            )}
          </div>

          <h1 class="text-3xl md:text-4xl lg:text-5xl font-extrabold text-surface-900 dark:text-surface-100 mb-5 leading-tight">
            {entry.data.title}
          </h1>
          <p class="text-lg text-surface-500 dark:text-surface-400 mb-5 leading-relaxed">{entry.data.description}</p>

          <div class="flex items-center gap-4 text-sm text-surface-400">
            <span class="flex items-center gap-1.5">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
              {entry.data.author}
            </span>
            <span class="flex items-center gap-1.5">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
              <time datetime={entry.data.publishDate.toISOString()}>{formattedDate}</time>
            </span>
          </div>

          {entry.data.tags.length > 0 && (
            <div class="flex flex-wrap gap-2 mt-5">
              {entry.data.tags.map((tag: string) => (
                <span class="px-3 py-1 text-xs rounded-full bg-surface-100 dark:bg-surface-800 text-surface-500 dark:text-surface-400 font-medium">#{tag}</span>
              ))}
            </div>
          )}
        </header>

        <!-- Mobile TOC -->
        <div class="lg:hidden mb-8 p-4 bg-surface-50 dark:bg-surface-900 rounded-xl border border-surface-200 dark:border-surface-800">
          <TableOfContents client:load />
        </div>

        <!-- Article Content -->
        <div class="prose max-w-none" data-pagefind-body>
          <Content />
        </div>

        <!-- Related Guides -->
        {entry.data.relatedGuides.length > 0 && (
          <div class="mt-12 pt-8 border-t border-surface-200 dark:border-surface-800">
            <h2 class="text-2xl font-bold text-surface-900 dark:text-surface-100 mb-6">{t['guide.related']}</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              {entry.data.relatedGuides.map((relatedSlug: string) => (
                <a href={`/${lang}/guides/${relatedSlug}`} class="group block p-5 rounded-xl border border-surface-200 dark:border-surface-800 hover:border-primary-300 dark:hover:border-primary-700 transition-all duration-300 hover:shadow-md">
                  <span class="text-sm font-medium text-primary-600 dark:text-primary-400 group-hover:underline">{relatedSlug}</span>
                  <svg class="w-4 h-4 inline-block ml-1 group-hover:translate-x-1 transition-transform text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
                </a>
              ))}
            </div>
          </div>
        )}

        <!-- Comments -->
        <div class="mt-12 pt-8 border-t border-surface-200 dark:border-surface-800">
          <h2 class="text-2xl font-bold text-surface-900 dark:text-surface-100 mb-6">Comments</h2>
          <GiscusComments client:visible lang={lang} />
        </div>
      </article>
    </div>
  </div>
</BaseLayout>
