---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getTranslations, type Lang } from '../../i18n/ui';

export const getStaticPaths: GetStaticPaths = async () => {
  const langs: Lang[] = ['en', 'zh-cn', 'ja', 'ko', 'es', 'pt'];
  return langs.map((lang) => ({ params: { lang } }));
};

const { lang } = Astro.params as { lang: Lang };
const t = getTranslations(lang);
---

<BaseLayout title={t['contact.title']} description={t['contact.subtitle']}>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8 page-enter">
    <h1 class="text-4xl md:text-5xl font-extrabold text-surface-900 dark:text-surface-100 mb-3">
      {t['contact.title']}
    </h1>
    <p class="text-lg text-surface-500 dark:text-surface-400 mb-10">
      {t['contact.subtitle']}
    </p>

    <div class="grid grid-cols-1 lg:grid-cols-5 gap-8">
      <!-- Email Contact Card -->
      <div class="lg:col-span-2">
        <div class="bg-white dark:bg-surface-900 rounded-2xl border border-surface-200 dark:border-surface-800 p-6 sticky top-24">
          <div class="flex items-center justify-center w-14 h-14 rounded-2xl bg-primary-100 dark:bg-primary-900/30 text-primary-600 dark:text-primary-400 mb-5">
            <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
          </div>
          <h2 class="text-xl font-bold text-surface-900 dark:text-surface-100 mb-2">
            {t['contact.email.title']}
          </h2>
          <p class="text-sm text-surface-500 dark:text-surface-400 mb-4">
            {t['contact.email.desc']}
          </p>
          <a
            href="mailto:tanglitian74@gmail.com"
            class="inline-flex items-center gap-2 px-5 py-3 rounded-xl bg-primary-600 text-white font-bold hover:bg-primary-700 transition-all duration-300 shadow-lg hover:shadow-xl hover:-translate-y-0.5"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
            tanglitian74@gmail.com
          </a>

          <div class="mt-8 pt-6 border-t border-surface-200 dark:border-surface-800">
            <h3 class="text-sm font-bold text-surface-700 dark:text-surface-300 mb-3 uppercase tracking-wider">
              {lang === 'zh-cn' ? '合作类型' : 'Cooperation Types'}
            </h3>
            <ul class="space-y-2.5">
              <li class="flex items-center gap-2 text-sm text-surface-600 dark:text-surface-400">
                <svg class="w-4 h-4 text-primary-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                {lang === 'zh-cn' ? '横幅广告 / Banner Ads' : 'Banner Ads'}
              </li>
              <li class="flex items-center gap-2 text-sm text-surface-600 dark:text-surface-400">
                <svg class="w-4 h-4 text-primary-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                {lang === 'zh-cn' ? '赞助内容 / Sponsored Content' : 'Sponsored Content'}
              </li>
              <li class="flex items-center gap-2 text-sm text-surface-600 dark:text-surface-400">
                <svg class="w-4 h-4 text-primary-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                {lang === 'zh-cn' ? '联盟营销 / Affiliate Marketing' : 'Affiliate Marketing'}
              </li>
              <li class="flex items-center gap-2 text-sm text-surface-600 dark:text-surface-400">
                <svg class="w-4 h-4 text-primary-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                {lang === 'zh-cn' ? '内容合作 / Content Partnership' : 'Content Partnership'}
              </li>
            </ul>
          </div>
        </div>
      </div>

      <!-- Contact Form (mailto) -->
      <div class="lg:col-span-3">
        <div class="bg-white dark:bg-surface-900 rounded-2xl border border-surface-200 dark:border-surface-800 p-6 md:p-8">
          <h2 class="text-xl font-bold text-surface-900 dark:text-surface-100 mb-6">
            {t['contact.form.title']}
          </h2>

          <form id="contact-form" class="space-y-5">
            <div>
              <label for="name" class="block text-sm font-medium text-surface-700 dark:text-surface-300 mb-1.5">
                {t['contact.form.name']} *
              </label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="w-full px-4 py-3 rounded-xl border border-surface-300 dark:border-surface-700 bg-white dark:bg-surface-800 text-surface-900 dark:text-surface-100 focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors outline-none"
                placeholder={lang === 'zh-cn' ? '您的姓名' : 'John Doe'}
              />
            </div>

            <div>
              <label for="email" class="block text-sm font-medium text-surface-700 dark:text-surface-300 mb-1.5">
                {t['contact.form.email']} *
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full px-4 py-3 rounded-xl border border-surface-300 dark:border-surface-700 bg-white dark:bg-surface-800 text-surface-900 dark:text-surface-100 focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors outline-none"
                placeholder="you@company.com"
              />
            </div>

            <div>
              <label for="subject" class="block text-sm font-medium text-surface-700 dark:text-surface-300 mb-1.5">
                {t['contact.form.subject']} *
              </label>
              <select
                id="subject"
                name="subject"
                required
                class="w-full px-4 py-3 rounded-xl border border-surface-300 dark:border-surface-700 bg-white dark:bg-surface-800 text-surface-900 dark:text-surface-100 focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors outline-none"
              >
                <option value="ads">{t['contact.form.subject.ads']}</option>
                <option value="partner">{t['contact.form.subject.partner']}</option>
                <option value="other">{t['contact.form.subject.other']}</option>
              </select>
            </div>

            <div>
              <label for="message" class="block text-sm font-medium text-surface-700 dark:text-surface-300 mb-1.5">
                {t['contact.form.message']} *
              </label>
              <textarea
                id="message"
                name="message"
                required
                rows="6"
                class="w-full px-4 py-3 rounded-xl border border-surface-300 dark:border-surface-700 bg-white dark:bg-surface-800 text-surface-900 dark:text-surface-100 focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors outline-none resize-y"
                placeholder={lang === 'zh-cn' ? '请描述您的需求...' : 'Describe your inquiry...'}
              ></textarea>
            </div>

            <button
              type="submit"
              class="w-full px-6 py-3.5 rounded-xl bg-primary-600 text-white font-bold hover:bg-primary-700 transition-all duration-300 shadow-lg hover:shadow-xl hover:-translate-y-0.5 text-lg"
            >
              {t['contact.form.submit']}
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;

  const subjectMap: Record<string, string> = {
    ads: '[Ad Inquiry] Crimson Guide - Advertising',
    partner: '[Partnership] Crimson Guide - Collaboration',
    other: '[General] Crimson Guide - Contact',
  };

  form?.addEventListener('submit', (e) => {
    e.preventDefault();

    const name = (document.getElementById('name') as HTMLInputElement).value;
    const email = (document.getElementById('email') as HTMLInputElement).value;
    const subject = (document.getElementById('subject') as HTMLSelectElement).value;
    const message = (document.getElementById('message') as HTMLTextAreaElement).value;

    const body = `Name: ${name}\nEmail: ${email}\n\n${message}`;
    const mailtoUrl = `mailto:tanglitian74@gmail.com?subject=${encodeURIComponent(subjectMap[subject] || subject)}&body=${encodeURIComponent(body)}`;

    window.location.href = mailtoUrl;
  });
</script>
