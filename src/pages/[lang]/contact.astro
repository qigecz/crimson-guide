---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getTranslations, type Lang } from '../../i18n/ui';

export const getStaticPaths: GetStaticPaths = async () => {
  const langs: Lang[] = ['en', 'zh-cn', 'ja', 'ko', 'es', 'pt'];
  return langs.map((lang) => ({ params: { lang } }));
};

const { lang } = Astro.params as { lang: Lang };
const t = getTranslations(lang);
---

<BaseLayout title={t['contact.title']} description={t['contact.subtitle']}>
  <div class="max-w-3xl mx-auto px-6 py-12">
    <h1 class="text-2xl font-bold text-surface-900 dark:text-surface-100 mb-2">
      {t['contact.title']}
    </h1>
    <p class="text-sm text-surface-400 mb-10">
      {t['contact.subtitle']}
    </p>

    <div class="grid grid-cols-1 md:grid-cols-5 gap-8">
      <!-- Email Info -->
      <div class="md:col-span-2">
        <h2 class="text-sm font-semibold text-surface-900 dark:text-surface-100 mb-2">
          {t['contact.email.title']}
        </h2>
        <p class="text-xs text-surface-400 mb-4">
          {t['contact.email.desc']}
        </p>
        <a
          href="mailto:tanglitian74@gmail.com"
          class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium bg-surface-900 text-white dark:bg-surface-100 dark:text-surface-900 rounded-lg hover:opacity-90 transition-opacity"
        >
          tanglitian74@gmail.com
        </a>

        <div class="mt-8 pt-6 border-t border-surface-200 dark:border-surface-800">
          <h3 class="text-xs font-semibold text-surface-600 dark:text-surface-300 mb-3 uppercase tracking-wider">
            {lang === 'zh-cn' ? '合作类型' : 'Cooperation Types'}
          </h3>
          <ul class="space-y-2">
            <li class="text-xs text-surface-400">{lang === 'zh-cn' ? '横幅广告 / Banner Ads' : 'Banner Ads'}</li>
            <li class="text-xs text-surface-400">{lang === 'zh-cn' ? '赞助内容 / Sponsored Content' : 'Sponsored Content'}</li>
            <li class="text-xs text-surface-400">{lang === 'zh-cn' ? '联盟营销 / Affiliate Marketing' : 'Affiliate Marketing'}</li>
            <li class="text-xs text-surface-400">{lang === 'zh-cn' ? '内容合作 / Content Partnership' : 'Content Partnership'}</li>
          </ul>
        </div>
      </div>

      <!-- Contact Form -->
      <div class="md:col-span-3">
        <div class="border border-surface-200 dark:border-surface-800 rounded-lg p-6">
          <h2 class="text-sm font-semibold text-surface-900 dark:text-surface-100 mb-5">
            {t['contact.form.title']}
          </h2>

          <form id="contact-form" class="space-y-4">
            <div>
              <label for="name" class="block text-xs font-medium text-surface-500 dark:text-surface-400 mb-1">
                {t['contact.form.name']} *
              </label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="w-full px-3 py-2 text-sm rounded-lg border border-surface-200 dark:border-surface-700 bg-white dark:bg-surface-900 text-surface-900 dark:text-surface-100 focus:ring-1 focus:ring-surface-400 focus:border-surface-400 transition-colors outline-none"
                placeholder={lang === 'zh-cn' ? '您的姓名' : 'John Doe'}
              />
            </div>

            <div>
              <label for="email" class="block text-xs font-medium text-surface-500 dark:text-surface-400 mb-1">
                {t['contact.form.email']} *
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full px-3 py-2 text-sm rounded-lg border border-surface-200 dark:border-surface-700 bg-white dark:bg-surface-900 text-surface-900 dark:text-surface-100 focus:ring-1 focus:ring-surface-400 focus:border-surface-400 transition-colors outline-none"
                placeholder="you@company.com"
              />
            </div>

            <div>
              <label for="subject" class="block text-xs font-medium text-surface-500 dark:text-surface-400 mb-1">
                {t['contact.form.subject']} *
              </label>
              <select
                id="subject"
                name="subject"
                required
                class="w-full px-3 py-2 text-sm rounded-lg border border-surface-200 dark:border-surface-700 bg-white dark:bg-surface-900 text-surface-900 dark:text-surface-100 focus:ring-1 focus:ring-surface-400 focus:border-surface-400 transition-colors outline-none"
              >
                <option value="ads">{t['contact.form.subject.ads']}</option>
                <option value="partner">{t['contact.form.subject.partner']}</option>
                <option value="other">{t['contact.form.subject.other']}</option>
              </select>
            </div>

            <div>
              <label for="message" class="block text-xs font-medium text-surface-500 dark:text-surface-400 mb-1">
                {t['contact.form.message']} *
              </label>
              <textarea
                id="message"
                name="message"
                required
                rows="5"
                class="w-full px-3 py-2 text-sm rounded-lg border border-surface-200 dark:border-surface-700 bg-white dark:bg-surface-900 text-surface-900 dark:text-surface-100 focus:ring-1 focus:ring-surface-400 focus:border-surface-400 transition-colors outline-none resize-y"
                placeholder={lang === 'zh-cn' ? '请描述您的需求...' : 'Describe your inquiry...'}
              ></textarea>
            </div>

            <button
              type="submit"
              class="w-full px-5 py-2.5 text-sm font-medium bg-surface-900 text-white dark:bg-surface-100 dark:text-surface-900 rounded-lg hover:opacity-90 transition-opacity"
            >
              {t['contact.form.submit']}
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;

  const subjectMap: Record<string, string> = {
    ads: '[Ad Inquiry] Crimson Guide - Advertising',
    partner: '[Partnership] Crimson Guide - Collaboration',
    other: '[General] Crimson Guide - Contact',
  };

  form?.addEventListener('submit', (e) => {
    e.preventDefault();

    const name = (document.getElementById('name') as HTMLInputElement).value;
    const email = (document.getElementById('email') as HTMLInputElement).value;
    const subject = (document.getElementById('subject') as HTMLSelectElement).value;
    const message = (document.getElementById('message') as HTMLTextAreaElement).value;

    const body = `Name: ${name}\nEmail: ${email}\n\n${message}`;
    const mailtoUrl = `mailto:tanglitian74@gmail.com?subject=${encodeURIComponent(subjectMap[subject] || subject)}&body=${encodeURIComponent(body)}`;

    window.location.href = mailtoUrl;
  });
</script>
