---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getTranslations, languages, type Lang } from '../../i18n/ui';
import { getLangFromUrl } from '../../i18n/utils';

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({
    params: { lang },
  }));
}

const lang = getLangFromUrl(Astro.url);
const t = getTranslations(lang);

const categoryIcons: Record<string, string> = {
  story: '📖',
  equipment: '⚔️',
  skills: '✨',
  exploration: '🗺️',
  mounts: '🐎',
  bosses: '👹',
  beginners: '🌟',
  news: '📰',
};

const categories = ['story', 'equipment', 'skills', 'exploration', 'mounts', 'bosses', 'beginners', 'news'];
---

<BaseLayout title={t['hero.title']} description={t['hero.subtitle']}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Hero -->
    <section class="text-center py-20 mb-8">
      <h1 class="text-5xl md:text-6xl font-extrabold text-surface-900 dark:text-surface-50 mb-4">
        {t['hero.title']}
      </h1>
      <p class="text-xl text-surface-500 dark:text-surface-400 mb-8 max-w-2xl mx-auto">
        {t['hero.subtitle']}
      </p>
      <div class="flex justify-center gap-4">
        <a
          href={`/${lang}/guides`}
          class="px-6 py-3 bg-primary-600 text-white rounded-lg font-medium hover:bg-primary-700 transition-colors"
        >
          {t['hero.cta.guides']}
        </a>
        <a
          href={`/${lang}/map`}
          class="px-6 py-3 border border-surface-300 dark:border-surface-600 text-surface-700 dark:text-surface-300 rounded-lg font-medium hover:bg-surface-50 dark:hover:bg-surface-800 transition-colors"
        >
          {t['hero.cta.map']}
        </a>
      </div>
    </section>

    <!-- Category Grid -->
    <section class="mb-20">
      <h2 class="text-2xl font-bold text-center mb-8">{t['section.hot']}</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {categories.map((cat) => (
          <a
            href={`/${lang}/guides/${cat}`}
            class="p-6 bg-surface-50 dark:bg-surface-900 rounded-xl border border-surface-200 dark:border-surface-700 hover:border-primary-300 dark:hover:border-primary-700 transition-colors text-center group"
          >
            <div class="text-2xl mb-2">{categoryIcons[cat]}</div>
            <h3 class="font-semibold text-surface-800 dark:text-surface-200 group-hover:text-primary-600 dark:group-hover:text-primary-400">
              {t[`category.${cat}`]}
            </h3>
          </a>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>
