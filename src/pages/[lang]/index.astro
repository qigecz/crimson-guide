---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { getTranslations, languages, type Lang } from '../../i18n/ui';
import { getLangFromUrl } from '../../i18n/utils';

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({
    params: { lang },
  }));
}

const lang = getLangFromUrl(Astro.url);
const t = getTranslations(lang);

const categoryEmoji: Record<string, string> = {
  story: '📖',
  equipment: '⚔️',
  skills: '✨',
  exploration: '🗺️',
  mounts: '🐴',
  bosses: '👹',
  beginners: '🔰',
};

const categories = ['story', 'equipment', 'skills', 'exploration', 'mounts', 'bosses', 'beginners'];

const allGuides = await getCollection('guides');
const langGuides = allGuides
  .filter((entry) => entry.id.startsWith(`${lang}/guides/`))
  .sort((a, b) => {
    const dateA = a.data.publishDate?.getTime() || 0;
    const dateB = b.data.publishDate?.getTime() || 0;
    return dateB - dateA;
  })
  .slice(0, 8);

const latestNews = allGuides
  .filter((entry) => entry.id.startsWith(`${lang}/news/`))
  .sort((a, b) => {
    const dateA = a.data.publishDate?.getTime() || 0;
    const dateB = b.data.publishDate?.getTime() || 0;
    return dateB - dateA;
  })
  .slice(0, 3);
---

<BaseLayout title={t['hero.title']} description={t['hero.subtitle']}>
  <div class="max-w-3xl mx-auto px-6">
    <!-- Hero -->
    <section class="py-20 md:py-28 text-center">
      <h1 class="text-3xl md:text-4xl font-bold text-surface-900 dark:text-surface-100 mb-4 tracking-tight">
        {t['hero.title']}
      </h1>
      <p class="text-base text-surface-400 mb-8 max-w-lg mx-auto">
        {t['hero.subtitle']}
      </p>
      <a
        href={`/${lang}/guides`}
        class="inline-flex items-center gap-1.5 px-6 py-2.5 text-sm font-medium bg-surface-900 text-white dark:bg-surface-100 dark:text-surface-900 rounded-lg hover:opacity-90 transition-opacity"
      >
        {t['hero.cta.guides']}
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
      </a>
    </section>

    <!-- Categories -->
    <section class="mb-16">
      <h2 class="text-sm font-semibold text-surface-400 uppercase tracking-wider mb-4">{t['section.hot']}</h2>
      <div class="flex flex-wrap gap-2">
        {categories.map((cat) => (
          <a
            href={`/${lang}/guides/${cat}`}
            class="inline-flex items-center gap-1.5 px-4 py-2 text-sm text-surface-600 dark:text-surface-300 bg-surface-50 dark:bg-surface-800/50 rounded-lg hover:bg-surface-100 dark:hover:bg-surface-800 transition-colors"
          >
            <span>{categoryEmoji[cat]}</span>
            {t[`category.${cat}`]}
          </a>
        ))}
      </div>
    </section>

    <!-- Latest Guides -->
    {langGuides.length > 0 && (
      <section class="mb-16">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-sm font-semibold text-surface-400 uppercase tracking-wider">
            {lang === 'zh-cn' ? '最新攻略' : 'Latest Guides'}
          </h2>
          <a href={`/${lang}/guides`} class="text-xs text-surface-400 hover:text-surface-600 dark:hover:text-surface-300 transition-colors">
            {lang === 'zh-cn' ? '查看全部' : 'View all'} &rarr;
          </a>
        </div>
        <div>
          {langGuides.map((guide) => {
            const slug = guide.id.replace(new RegExp(`^${lang}/guides/`), '').replace(/\.(md|mdx)$/, '');
            const emoji = categoryEmoji[guide.data.category] || '📄';
            return (
              <a
                href={`/${lang}/guides/${slug}`}
                class="group flex items-start gap-3 py-4 border-b border-surface-100 dark:border-surface-800/50 hover:bg-surface-50 dark:hover:bg-surface-900/50 transition-colors px-3 -mx-3 rounded"
              >
                <div class="flex-shrink-0 w-9 h-9 flex items-center justify-center text-lg bg-surface-50 dark:bg-surface-800 rounded-lg">
                  {emoji}
                </div>
                <div class="flex-1 min-w-0">
                  <h3 class="text-sm font-medium text-surface-900 dark:text-surface-100 group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors line-clamp-1">
                    {guide.data.title}
                  </h3>
                  <p class="text-xs text-surface-400 line-clamp-1 mt-0.5">
                    {guide.data.description}
                  </p>
                </div>
                <span class="flex-shrink-0 text-xs text-surface-300 mt-1">
                  {guide.data.publishDate.toLocaleDateString(lang === 'zh-cn' ? 'zh-CN' : lang, { month: 'short', day: 'numeric' })}
                </span>
              </a>
            );
          })}
        </div>
      </section>
    )}

    <!-- Latest News -->
    {latestNews.length > 0 && (
      <section class="mb-16">
        <h2 class="text-sm font-semibold text-surface-400 uppercase tracking-wider mb-4">
          {t['section.latest']}
        </h2>
        <div>
          {latestNews.map((news) => {
            const slug = news.id.replace(new RegExp(`^${lang}/news/`), '').replace(/\.(md|mdx)$/, '');
            return (
              <a
                href={`/${lang}/news/${slug}`}
                class="group flex items-start gap-3 py-4 border-b border-surface-100 dark:border-surface-800/50 hover:bg-surface-50 dark:hover:bg-surface-900/50 transition-colors px-3 -mx-3 rounded"
              >
                <div class="flex-shrink-0 w-9 h-9 flex items-center justify-center text-lg bg-surface-50 dark:bg-surface-800 rounded-lg">
                  📰
                </div>
                <div class="flex-1 min-w-0">
                  <h3 class="text-sm font-medium text-surface-900 dark:text-surface-100 group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors line-clamp-1">
                    {news.data.title}
                  </h3>
                  <p class="text-xs text-surface-400 line-clamp-1 mt-0.5">
                    {news.data.description}
                  </p>
                </div>
                <span class="flex-shrink-0 text-xs text-surface-300 mt-1">
                  {news.data.publishDate.toLocaleDateString(lang === 'zh-cn' ? 'zh-CN' : lang, { month: 'short', day: 'numeric' })}
                </span>
              </a>
            );
          })}
        </div>
      </section>
    )}
  </div>
</BaseLayout>
