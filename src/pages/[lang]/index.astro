---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { getTranslations, languages, type Lang } from '../../i18n/ui';
import { getLangFromUrl } from '../../i18n/utils';

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({
    params: { lang },
  }));
}

const lang = getLangFromUrl(Astro.url);
const t = getTranslations(lang);

const categoryConfig: Record<string, { icon: string; cssClass: string; iconClass: string }> = {
  story: { icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>`, cssClass: 'cat-story', iconClass: 'cat-icon-story' },
  equipment: { icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>`, cssClass: 'cat-equipment', iconClass: 'cat-icon-equipment' },
  skills: { icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L9 9H2l6 4.5L5.5 22 12 17l6.5 5L16 13.5 22 9h-7z"/></svg>`, cssClass: 'cat-skills', iconClass: 'cat-icon-skills' },
  exploration: { icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="3 6 9 3 15 6 21 3 21 18 15 21 9 18 3 21"/><line x1="9" y1="3" x2="9" y2="18"/><line x1="15" y1="6" x2="15" y2="21"/></svg>`, cssClass: 'cat-exploration', iconClass: 'cat-icon-exploration' },
  mounts: { icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 10c0-2-1-4-3-4s-3 1-4 2l-2 2-2-2c-1-1-2-2-4-2s-3 2-3 4"/><circle cx="8" cy="18" r="2"/><circle cx="16" cy="18" r="2"/><path d="M6 10l1 6h10l1-6"/><path d="M4 10h16"/></svg>`, cssClass: 'cat-mounts', iconClass: 'cat-icon-mounts' },
  bosses: { icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg>`, cssClass: 'cat-bosses', iconClass: 'cat-icon-bosses' },
  beginners: { icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2a10 10 0 1 0 10 10H12V2z"/><path d="M20 12a8 8 0 0 0-8-8v8h8z"/></svg>`, cssClass: 'cat-beginners', iconClass: 'cat-icon-beginners' },
  news: { icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 22h16a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v16a2 2 0 0 1-2 2zm0 0a2 2 0 0 1-2-2v-9c0-1.1.9-2 2-2h2"/><line x1="10" y1="6" x2="18" y2="6"/><line x1="10" y1="10" x2="18" y2="10"/><line x1="10" y1="14" x2="14" y2="14"/></svg>`, cssClass: 'cat-news', iconClass: 'cat-icon-news' },
};

const categories = ['story', 'equipment', 'skills', 'exploration', 'mounts', 'bosses', 'beginners', 'news'];

// Get latest guides for featured section
const allGuides = await getCollection('guides');
const langGuides = allGuides
  .filter((entry) => entry.id.startsWith(`${lang}/guides/`) && !entry.id.includes('/news/'))
  .sort((a, b) => {
    const dateA = a.data.publishDate?.getTime() || 0;
    const dateB = b.data.publishDate?.getTime() || 0;
    return dateB - dateA;
  })
  .slice(0, 3);

const latestNews = allGuides
  .filter((entry) => entry.id.startsWith(`${lang}/news/`))
  .sort((a, b) => {
    const dateA = a.data.publishDate?.getTime() || 0;
    const dateB = b.data.publishDate?.getTime() || 0;
    return dateB - dateA;
  })
  .slice(0, 2);
---

<BaseLayout title={t['hero.title']} description={t['hero.subtitle']}>
  <div class="page-enter">
    <!-- Hero Section -->
    <section class="hero-gradient hero-particles relative">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 md:py-32 relative z-10">
        <div class="text-center">
          <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-white/15 dark:bg-white/10 backdrop-blur-sm text-white/90 text-sm font-medium mb-6 badge-pulse">
            <span class="w-2 h-2 rounded-full bg-green-400 animate-pulse"></span>
            Crimson Desert
          </div>
          <h1 class="text-5xl md:text-7xl font-extrabold text-white mb-6 tracking-tight drop-shadow-lg">
            {t['hero.title']}
          </h1>
          <p class="text-xl md:text-2xl text-white/80 mb-10 max-w-2xl mx-auto leading-relaxed">
            {t['hero.subtitle']}
          </p>
          <div class="flex flex-col sm:flex-row justify-center gap-4">
            <a
              href={`/${lang}/guides`}
              class="px-8 py-4 bg-white text-primary-700 rounded-xl font-bold hover:bg-white/90 transition-all duration-300 shadow-lg shadow-black/20 hover:shadow-xl hover:-translate-y-0.5 text-lg"
            >
              {t['hero.cta.guides']}
            </a>
            <a
              href={`/${lang}/map`}
              class="px-8 py-4 border-2 border-white/40 text-white rounded-xl font-bold hover:bg-white/15 transition-all duration-300 hover:-translate-y-0.5 text-lg"
            >
              {t['hero.cta.map']}
            </a>
          </div>
        </div>
      </div>
      <!-- Bottom fade -->
      <div class="absolute bottom-0 left-0 right-0 h-24 bg-gradient-to-t from-white dark:from-surface-950 to-transparent"></div>
    </section>

    <!-- Category Grid -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 -mt-8 relative z-10 mb-20">
      <h2 class="text-2xl font-bold text-center mb-8 text-surface-900 dark:text-surface-100">{t['section.hot']}</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {categories.map((cat) => {
          const config = categoryConfig[cat];
          return (
            <a
              href={cat === 'news' ? `/${lang}/news` : `/${lang}/guides/${cat}`}
              class:list={['group card-shine rounded-2xl border border-surface-200/60 dark:border-surface-700/60 hover:border-primary-300 dark:hover:border-primary-700 transition-all duration-300 hover:-translate-y-1 hover:shadow-xl', config.cssClass]}
            >
              <div class="p-6 text-center">
                <div class:list={['w-12 h-12 mx-auto mb-3', config.iconClass]} set:html={config.icon} />
                <h3 class="font-bold text-surface-800 dark:text-surface-100 group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors text-sm md:text-base">
                  {t[`category.${cat}`]}
                </h3>
              </div>
            </a>
          );
        })}
      </div>
    </section>

    <!-- Featured Guides -->
    {langGuides.length > 0 && (
      <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-20">
        <div class="flex items-center justify-between mb-8">
          <h2 class="text-2xl font-bold text-surface-900 dark:text-surface-100">{lang === 'zh-cn' ? '最新攻略' : 'Latest Guides'}</h2>
          <a href={`/${lang}/guides`} class="text-sm font-medium text-primary-600 dark:text-primary-400 hover:underline flex items-center gap-1">
            {lang === 'zh-cn' ? '查看全部' : 'View all'}
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
          </a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {langGuides.map((guide) => {
            const slug = guide.id.replace(new RegExp(`^${lang}/guides/`), '').replace(/\.(md|mdx)$/, '');
            const config = categoryConfig[guide.data.category];
            return (
              <a
                href={`/${lang}/guides/${slug}`}
                class="group card-shine block rounded-2xl overflow-hidden bg-white dark:bg-surface-900 border border-surface-200 dark:border-surface-800 hover:border-primary-300 dark:hover:border-primary-700 hover:shadow-xl transition-all duration-300 hover:-translate-y-1"
              >
                <div class="h-48 relative overflow-hidden">
                  <div class:list={['absolute inset-0', config?.cssClass || 'bg-surface-100']}></div>
                  <div class="absolute inset-0 flex items-center justify-center">
                    <div class:list={['w-16 h-16 opacity-30', config?.iconClass || '']} set:html={config?.icon || ''} />
                  </div>
                  <span class="absolute top-3 left-3 px-3 py-1 text-xs font-bold rounded-lg bg-primary-600 text-white shadow-md">
                    {t[`category.${guide.data.category}`]}
                  </span>
                  {guide.data.difficulty && (
                    <span class:list={[
                      'absolute top-3 right-3 px-2 py-1 text-xs font-semibold rounded-lg',
                      guide.data.difficulty === 'beginner' ? 'bg-green-500 text-white' : guide.data.difficulty === 'intermediate' ? 'bg-yellow-500 text-white' : 'bg-red-500 text-white',
                    ]}>
                      {guide.data.difficulty}
                    </span>
                  )}
                </div>
                <div class="p-5">
                  <h3 class="text-lg font-bold text-surface-900 dark:text-surface-100 group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors line-clamp-2 mb-2">
                    {guide.data.title}
                  </h3>
                  <p class="text-sm text-surface-600 dark:text-surface-400 line-clamp-2 mb-3">
                    {guide.data.description}
                  </p>
                  <div class="flex items-center gap-2 text-xs text-surface-400">
                    <time>{guide.data.publishDate.toLocaleDateString(lang === 'zh-cn' ? 'zh-CN' : lang, { month: 'short', day: 'numeric', year: 'numeric' })}</time>
                  </div>
                </div>
              </a>
            );
          })}
        </div>
      </section>
    )}

    <!-- Latest News -->
    {latestNews.length > 0 && (
      <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-20">
        <h2 class="text-2xl font-bold mb-8 text-surface-900 dark:text-surface-100">{t['section.latest']}</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {latestNews.map((news) => {
            const slug = news.id.replace(new RegExp(`^${lang}/news/`), '').replace(/\.(md|mdx)$/, '');
            return (
              <a
                href={`/${lang}/news/${slug}`}
                class="group block p-6 rounded-2xl bg-white dark:bg-surface-900 border border-surface-200 dark:border-surface-800 hover:border-primary-300 dark:hover:border-primary-700 hover:shadow-lg transition-all duration-300"
              >
                <div class="flex items-center gap-2 mb-3">
                  <span class="px-2 py-0.5 text-xs font-bold rounded bg-primary-100 dark:bg-primary-900/30 text-primary-700 dark:text-primary-400">NEWS</span>
                  <time class="text-xs text-surface-400">{news.data.publishDate.toLocaleDateString(lang === 'zh-cn' ? 'zh-CN' : lang, { month: 'short', day: 'numeric', year: 'numeric' })}</time>
                </div>
                <h3 class="text-lg font-bold text-surface-900 dark:text-surface-100 group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors mb-2">
                  {news.data.title}
                </h3>
                <p class="text-sm text-surface-500 dark:text-surface-400 line-clamp-2">{news.data.description}</p>
              </a>
            );
          })}
        </div>
      </section>
    )}
  </div>
</BaseLayout>
