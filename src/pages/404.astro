---
import '../styles/global.css';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>404 - Page Not Found | Crimson Guide</title>
  </head>
  <body class="min-h-screen flex items-center justify-center bg-white dark:bg-surface-950 text-surface-900 dark:text-surface-100">
    <div class="text-center px-4">
      <h1 class="text-6xl font-bold text-primary-600 mb-4">404</h1>
      <p class="text-xl text-surface-600 dark:text-surface-400 mb-8">
        Page not found. The guide you're looking for doesn't exist yet.
      </p>
      <a
        href="/en"
        class="px-6 py-3 rounded-lg bg-primary-600 text-white font-medium hover:bg-primary-700 transition-colors"
      >
        Go Home
      </a>
    </div>
  </body>
</html>
