---
import '../styles/global.css';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>404 - Page Not Found | Crimson Guide</title>
  </head>
  <body class="min-h-screen flex items-center justify-center bg-white dark:bg-surface-950 text-surface-900 dark:text-surface-100">
    <div class="text-center px-6">
      <div class="text-6xl font-bold text-surface-200 dark:text-surface-800 mb-4">404</div>
      <h1 class="text-lg font-bold text-surface-900 dark:text-surface-100 mb-2">Page Not Found</h1>
      <p class="text-sm text-surface-400 mb-8 max-w-sm mx-auto">
        The guide you're looking for doesn't exist yet. Perhaps it's still being written.
      </p>
      <a
        href="/en"
        class="inline-flex items-center gap-1.5 px-5 py-2.5 text-sm font-medium bg-surface-900 text-white dark:bg-surface-100 dark:text-surface-900 rounded-lg hover:opacity-90 transition-opacity"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" /></svg>
        Go Home
      </a>
    </div>
  </body>
</html>
